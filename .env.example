# Supabase Postgres connection
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres?sslmode=require

# Google Gemini API key for report summarization
GEMINI_API_KEY=your_gemini_api_key_here
# Optional alias; app will also read this if GEMINI_API_KEY is not set
GOOGLE_API_KEY=your_google_api_key_here

# SMTP configuration for Medisyn Connect booking emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_SECURE=false

